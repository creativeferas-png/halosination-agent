# ============================================================================
# HALO — .env.example
# Copy to .env and fill in your Compass API key.
# Never commit the real key. .env is gitignored.
# ============================================================================

# --- Compass API (required) ---
# Get your key from the Compass platform.
# NOTE: Use api.core42.ai/v1 (the API endpoint). The official checklist lists
# compass.core42.ai/v1 but that is the web portal, not the API.
# See README.md "A note on the Compass URL" for the full explanation.
OPENAI_API_KEY=your_compass_api_key_here
OPENAI_BASE_URL=https://api.core42.ai/v1

# --- Model configuration (optional - sensible defaults shown) ---
# HALO uses GPT-4.1 for Intake/Validator/Router (high-volume reasoning)
# and GPT-5.1 for Brush (creative generation), per Compass guidance.
MODEL_NAME=gpt-4.1
REASONING_MODEL_NAME=gpt-5.1
EMBEDDING_MODEL_NAME=text-embedding-3-large

# --- Sample mode (optional) ---
# If you want to test the agent pipeline without making real Compass calls
# (e.g. offline or in CI), set SAMPLE_MODE=true. NOT used in the submitted
# version - the submitted system always makes real Compass calls.
SAMPLE_MODE=false
